{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		"helpers:pinGitHubActionDigests",
		":configMigration",
		"security:minimumReleaseAgeNpm"
	],
	"labels": ["Dependencies"],
	"ignoreDeps": ["pnpm"],
	"dependencyDashboard": true,
	"rebaseWhen": "conflicted",
	"rangeStrategy": "bump",
	"commitMessageTopic": "{{depName}}",
	"commitMessageAction": "Update",
	"commitMessageExtra": "to {{#if isMajor}}v{{newMajor}}{{else}}v{{newVersion}}{{/if}}",
	"commitMessageSuffix": "",
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 5am on monday"]
	},
	"packageRules": [
		{
			"description": "Tag safe (non-major) updates so they can be auto-merged by CI automation",
			"matchUpdateTypes": [
				"minor",
				"patch",
				"pin",
				"digest"
			],
			"addLabels": [
				"automerge"
			]
		},
		{
			"description": "Never raise PRs for npm peerDependencies",
			"matchManagers": [
				"npm"
			],
			"matchDepTypes": [
				"peerDependencies"
			],
			"enabled": false
		},
		{
			"description": "Catch-all npm minor/patch updates - grouped, weekly, with a supply-chain cool-off",
			"matchManagers": [
				"npm"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"groupName": "npm-dependencies",
			"addLabels": [
				"JavaScript"
			],
			"schedule": [
				"before 6am on monday"
			],
			"minimumReleaseAge": "5 days"
		},
		{
			"description": "ESLint & Prettier tooling",
			"matchManagers": [
				"npm"
			],
			"groupName": "Linting",
			"matchPackageNames": [
				"/eslint/",
				"/prettier/"
			],
			"addLabels": [
				"JavaScript"
			],
			"schedule": [
				"before 6am on monday"
			],
			"minimumReleaseAge": "5 days"
		},
		{
			"description": "Cypress end-to-end tooling",
			"matchManagers": [
				"npm"
			],
			"groupName": "Cypress",
			"matchPackageNames": [
				"cypress",
				"/^cypress-/",
				"mocha",
				"/^mochawesome/"
			],
			"addLabels": [
				"JavaScript"
			],
			"schedule": [
				"before 6am on monday"
			],
			"minimumReleaseAge": "5 days"
		},
		{
			"description": "React core - keep react / react-dom / router / type defs in lock-step",
			"matchManagers": [
				"npm"
			],
			"groupName": "React",
			"matchPackageNames": [
				"react",
				"react-dom",
				"/^react-router/",
				"/^@types\\/react/"
			],
			"addLabels": [
				"JavaScript"
			],
			"schedule": [
				"before 6am on monday"
			],
			"minimumReleaseAge": "5 days"
		},
		{
			"description": "Frank!Framework packages",
			"matchManagers": [
				"npm"
			],
			"groupName": "Frank!Framework",
			"matchPackageNames": [
				"/^@frankframework\\//"
			],
			"addLabels": [
				"JavaScript"
			],
			"schedule": [
				"before 6am on monday"
			]
		},
		{
			"description": "Maven (incl. wrapper) - daily early morning, Java label, supply-chain cool-off",
			"matchManagers": [
				"maven",
				"maven-wrapper"
			],
			"schedule": [
				"0 0-6 * * *"
			],
			"addLabels": [
				"Java"
			],
			"minimumReleaseAge": "5 days"
		},
		{
			"description": "Group Maven patch updates into a single PR",
			"matchManagers": [
				"maven"
			],
			"matchUpdateTypes": [
				"patch"
			],
			"groupName": "maven-dependencies"
		},
		{
			"description": "Spring Boot / Framework - update together, split minor vs patch",
			"matchManagers": [
				"maven"
			],
			"groupName": "Spring",
			"matchPackageNames": [
				"/^org\\.springframework/"
			],
			"separateMinorPatch": true
		},
		{
			"description": "Container base images - daily early morning, grouped",
			"matchManagers": [
				"dockerfile",
				"docker-compose"
			],
			"schedule": [
				"0 0-6 * * *"
			],
			"addLabels": [
				"Docker"
			],
			"groupName": "Docker"
		},
		{
			"description": "GitHub Actions - weekly, single grouped PR, pinned to commit digests",
			"matchManagers": [
				"github-actions"
			],
			"schedule": [
				"before 6am on monday"
			],
			"addLabels": [
				"CI/CD"
			],
			"groupName": "github-actions",
			"separateMajorMinor": false,
			"minimumReleaseAge": "7 days"
		}
	],
	"vulnerabilityAlerts": {
		"enabled": true,
		"labels": [
			"Security",
			"Dependencies"
		],
		"addLabels": [
			"CVE"
		]
	},
	"osvVulnerabilityAlerts": true
}
